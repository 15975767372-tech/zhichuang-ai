<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI文案生成工具</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: "微软雅黑", sans-serif; }
        body { background: #f5f7fa; padding: 40px 20px; }
        .container { max-width: 600px; margin: 0 auto; background: #fff; padding: 30px; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
        h1 { text-align: center; color: #333; margin-bottom: 25px; font-size: 22px; }
        .input-box { margin-bottom: 20px; }
        label { display: block; color: #666; margin-bottom: 8px; font-size: 14px; }
        textarea { width: 100%; height: 100px; padding: 12px; border: 1px solid #ddd; border-radius: 8px; resize: none; font-size: 15px; outline: none; }
        textarea:focus { border-color: #409eff; }
        .btn { width: 100%; height: 48px; background: #409eff; color: #fff; border: none; border-radius: 8px; font-size: 16px; cursor: pointer; margin-bottom: 20px; }
        .btn:active { opacity: 0.8; }
        .result-box { background: #f8f9fa; padding: 15px; border-radius: 8px; min-height: 100px; color: #333; font-size: 15px; line-height: 1.6; }
        .tip { text-align: center; color: #999; font-size: 12px; margin-top: 15px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>AI爆款文案生成器</h1>
        <div class="input-box">
            <label>输入你的产品/主题关键词</label>
            <textarea id="keyword" placeholder="例如：夏天短袖、护肤精华"></textarea>
        </div>
        <button class="btn" onclick="generate()">一键生成文案</button>
        <div class="result-box" id="result">生成的文案会显示在这里</div>
        <div class="tip">AI生成仅供参考，可自行修改调整</div>
    </div>

    <script>
        async function generate() {
            const keyword = document.getElementById('keyword').value.trim();
            if (!keyword) {
                alert('请先输入关键词');
                return;
            }
            document.getElementById('result').innerText = '正在生成中...';
            
            try {
                const res = await fetch('/api/generate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ keyword })
                });
                const data = await res.json();
                document.getElementById('result').innerText = data.content;
            } catch (e) {
                document.getElementById('result').innerText = '生成失败，请刷新重试';
            }
        }
    </script>
</body>
</html>
